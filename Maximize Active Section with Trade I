class Solution {

    public int maxActiveSectionsAfterTrade(String s) {

        int ones = 0;
        int previousZero = Integer.MIN_VALUE;
        int maxGain = 0;

        int i = 0;

        while (i < s.length()) {

            int j = i;

            while (j < s.length() && s.charAt(j) == s.charAt(i)) {
                j++;
            }

            int length = j - i;

            if (s.charAt(i) == '1') {

                ones += length;

            } else {

                maxGain = Math.max(maxGain, previousZero + length);
                previousZero = length;

            }

            i = j;
        }

        return ones + maxGain;
    }
}
